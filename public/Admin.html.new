<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GLAMOURS | Panel Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        serif: ['Playfair Display', 'serif'],
                    },
                    colors: {
                        vs: { pink: '#E0007F', black: '#000', gray: '#767676', light: '#F6F6F6' }
                    }
                }
            }
        }
    </script>
    <style>
        body { 
            background: linear-gradient(135deg, #fefae0 0%, #faedcd 50%, #f4a261 100%);
            background-attachment: fixed;
            color: #2d3142;
            font-family: 'Inter', sans-serif; 
            min-height: 100vh;
        }
        .tab-btn.active { border-bottom: 3px solid #ff6b35; color: #ff6b35; font-weight: bold; }
        .vs-button { background: #2d3142; color: #fff; padding: 12px 32px; font-weight: 600; transition: all 0.3s ease; }
        .vs-button:hover { background: #ff6b35; }
        .glass-card { background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(10px); border-radius: 1.5rem; border: 1px solid rgba(255,255,255,0.5); shadow: 0 10px 30px rgba(0,0,0,0.05); }
    </style>
</head>
<body class="p-4 md:p-8">

    <div id="admin-login-overlay" class="fixed inset-0 bg-gray-900/95 z-[200] flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl p-8 w-full max-w-md">
            <h2 class="text-2xl font-bold mb-6 text-center">Acceso Admin</h2>
            <form id="admin-login-form" class="space-y-4">
                <input type="text" id="admin-user" placeholder="Usuario" required class="w-full px-4 py-3 border rounded-xl">
                <input type="password" id="admin-pass" placeholder="Clave" required class="w-full px-4 py-3 border rounded-xl">
                <button type="submit" class="w-full bg-black text-white py-4 rounded-xl font-bold">Entrar</button>
            </form>
        </div>
    </div>

    <div id="admin-panel" class="hidden max-w-6xl mx-auto space-y-6">
        <div class="bg-black text-white p-6 rounded-2xl flex justify-between items-center shadow-xl">
            <h1 class="text-xl font-bold">GLAMOURS Admin</h1>
            <button onclick="logoutAdmin()" class="text-red-400 text-sm font-bold">Cerrar Sesión</button>
        </div>

        <div class="flex border-b border-gray-200">
            <button onclick="showTab('productos')" id="btn-productos" class="tab-btn active px-6 py-3">Productos</button>
            <button onclick="showTab('imagenes')" id="btn-imagenes" class="tab-btn px-6 py-3">Imágenes 📷</button>
            <button onclick="showTab('portada')" id="btn-portada" class="tab-btn px-6 py-3 text-orange-600 font-bold">Portada ✨</button>
            <button onclick="showTab('usuarios')" id="btn-usuarios" class="tab-btn px-6 py-3">Usuarios</button>
            <button onclick="showTab('ajustes')" id="btn-ajustes" class="tab-btn px-6 py-3">Ajustes</button>
        </div>

        <div id="tab-productos" class="tab-content grid grid-cols-1 lg:grid-cols-2 gap-8">
            <div class="bg-white rounded-2xl shadow p-8">
                <h2 id="form-title" class="text-xl font-bold mb-6">Nuevo Producto</h2>
                <form id="productForm" class="space-y-4">
                    <input type="hidden" id="edit-id">
                    <input type="text" id="nombre" placeholder="Nombre" required class="w-full px-4 py-2 border rounded-lg">
                    <input type="number" id="precio" placeholder="Precio ($)" required class="w-full px-4 py-2 border rounded-lg">
                    <select id="marca" class="w-full px-4 py-2 border rounded-lg">
                        <option>Sail</option><option>Legacy</option><option>47 Street</option><option>Owoko</option>
                    </select>
                    <input type="url" id="imagen" placeholder="URL de Imagen" required class="w-full px-4 py-2 border rounded-lg">
                    <div class="grid grid-cols-2 gap-4">
                        <input type="text" id="colores" placeholder="Colores (ej: Rojo, Azul)" class="w-full px-4 py-2 border rounded-lg">
                        <input type="text" id="talles" placeholder="Talles (ej: S, M, L o 38, 39)" class="w-full px-4 py-2 border rounded-lg">
                    </div>
                    <textarea id="descripcion" placeholder="Descripción" class="w-full px-4 py-2 border rounded-lg"></textarea>
                    <div class="flex gap-4">
                        <label><input type="checkbox" id="novedad"> Novedad</label>
                        <label><input type="checkbox" id="oferta" onchange="toggleDiscountField()"> Oferta</label>
                        <label><input type="checkbox" id="portada"> Portada</label>
                    </div>
                    <div id="discount-container" class="hidden">
                        <label class="block text-sm font-medium mb-1">Porcentaje de Descuento (%)</label>
                        <input type="number" id="descuento" placeholder="ej: 20" min="1" max="99" class="w-full px-4 py-2 border rounded-lg">
                    </div>
                    <button type="submit" id="submit-btn" class="w-full bg-black text-white py-3 rounded-lg font-bold">Guardar</button>
                    <button type="button" id="cancel-edit" class="hidden w-full border border-gray-200 py-2 rounded-lg text-sm mt-2">Cancelar Edición</button>
                </form>
            </div>
            <div class="bg-white rounded-2xl shadow p-8">
                <h2 class="text-xl font-bold mb-6">Inventario</h2>
                <div id="product-list" class="space-y-4 max-h-[500px] overflow-y-auto"></div>
            </div>
        </div>

        <!-- TAB: IMAGENES -->
        <div id="tab-imagenes" class="tab-content hidden bg-white rounded-2xl shadow p-8">
            <h2 class="text-xl font-bold mb-2">Subir Imágenes a Internet</h2>
            <p class="text-sm text-gray-500 mb-6">Seguí estos pasos para obtener unaURL pública de tu imagen.</p>
            
            <div class="border-2 border-dashed border-gray-300 rounded-xl p-6 text-center">
                <input type="file" id="image-upload" accept="image/*" class="hidden" onchange="previewImage(event)">
                <label for="image-upload" class="cursor-pointer">
                    <div id="image-preview-area" class="py-6">
                        <i class="fa-solid fa-cloud-upload-alt text-4xl text-gray-400 mb-4"></i>
                        <p class="text-gray-500">Click para seleccionar una imagen de tu computadora</p>
                    </div>
                    <img id="preview-img" class="hidden max-h-48 mx-auto rounded-lg mb-4">
                </label>
            </div>
            
            <div id="image-result" class="hidden mt-6">
                <!-- Instrucciones paso a paso -->
                <div class="bg-blue-50 rounded-lg p-4 mb-4">
                    <h3 class="font-bold text-blue-800 mb-3">📋 Pasos para obtener la URL:</h3>
                    
                    <div class="flex items-start gap-3 mb-4">
                        <span class="bg-blue-600 text-white rounded-full w-6 h-6 flex items-center justify-center text-sm font-bold flex-shrink-0">1</span>
                        <div>
                            <p class="text-sm">Hacé click en el botón de abajo para ir a imgbb.com</p>
                            <a href="https://imgbb.com" target="_blank" class="inline-block mt-2 px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-bold hover:bg-blue-700">
                                <i class="fa-solid fa-external-link-alt mr-2"></i>Ir a imgbb.com
                            </a>
                        </div>
                    </div>
                    
                    <div class="flex items-start gap-3 mb-4">
                        <span class="bg-blue-600 text-white rounded-full w-6 h-6 flex items-center justify-center text-sm font-bold flex-shrink-0">2</span>
                        <div>
                            <p class="text-sm">Arrastrá tu imagen en la página de imgbb</p>
                        </div>
                    </div>
                    
                    <div class="flex items-start gap-3 mb-4">
                        <span class="bg-blue-600 text-white rounded-full w-6 h-6 flex items-center justify-center text-sm font-bold flex-shrink-0">3</span>
                        <div>
                            <p class="text-sm">Copiá la URL que aparece (comienza con <strong>https://i.ibb.co/</strong>)</p>
                        </div>
                    </div>
                    
                    <div class="flex items-start gap-3">
                        <span class="bg-blue-600 text-white rounded-full w-6 h-6 flex items-center justify-center text-sm font-bold flex-shrink-0">4</span>
                        <div>
                            <p class="text-sm">Pegala en "URL de Imagen" del producto</p>
                        </div>
                    </div>
                </div>
                
                <div class="bg-yellow-50 rounded-lg p-4 mb-4">
                    <p class="text-sm font-bold text-yellow-800">⚠️ Importante:</p>
                    <p class="text-xs text-yellow-700 mt-1">使用URL que termina en PNG/JPG/GIF/WEBP, ejemplo:<br><code>https://i.ibb.co/Z6tgM2SK/camisa1.png</code></p>
                </div>
                
                <div class="bg-green-50 rounded-lg p-4">
                    <p class="text-sm font-bold text-green-700 mb-2">✅ Después de pegar la URL en el producto:</p>
                    <p class="text-xs text-green-600">La imagen se verá en tu tienda automáticamente.</p>
                </div>
            </div>
        </div>

        <div id="tab-usuarios" class="tab-content hidden bg-white rounded-2xl shadow p-8">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-xl font-bold">Usuarios Registrados</h2>
                <button onclick="exportUsers()" class="bg-green-600 text-white px-4 py-2 rounded-lg text-xs font-bold">Exportar CSV</button>
            </div>
            <div id="user-list-table" class="overflow-x-auto"></div>
        </div>

        <div id="tab-portada" class="tab-content hidden bg-white rounded-2xl shadow p-8 max-w-2xl mx-auto">
            <h2 class="text-xl font-bold mb-6">Gestión de Portada (Home)</h2>
            <p class="text-sm text-gray-500 mb-6">Configura la imagen y textos principales que ven los clientes al entrar.</p>
            <form id="config-form" class="space-y-6">
                <div class="bg-black p-6 rounded-xl border border-gray-800 mb-6">
                    <label class="block text-white text-sm font-bold mb-2">Banner Superior (Anuncio en todo el sitio)</label>
                    <input type="text" id="topBanner" placeholder="Ej: Envíos GRATIS + $120.000 | 3 CUOTAS SIN INTERÉS" class="w-full px-4 py-3 bg-gray-900 text-white border border-gray-700 rounded-xl font-mono text-sm">
                    <p class="text-[10px] text-gray-500 mt-2 uppercase tracking-widest">Este mensaje aparecerá arriba de todo en todas las páginas.</p>
                </div>
                <div>
                    <label class="block text-sm font-bold mb-2">Título Hero (acepta HTML)</label>
                    <input type="text" id="heroTitle" required class="w-full px-4 py-3 border rounded-xl font-mono text-sm">
                </div>
                <div>
                    <label class="block text-sm font-bold mb-2">Descripción / Subtítulo</label>
                    <textarea id="heroDesc" required rows="3" class="w-full px-4 py-3 border rounded-xl text-sm"></textarea>
                </div>
                <div>
                    <label class="block text-sm font-bold mb-2">URL Imagen de Portada</label>
                    <input type="url" id="heroImage" required class="w-full px-4 py-3 border rounded-xl font-mono text-sm">
                </div>
                <div class="bg-red-50 p-4 rounded-xl border border-red-100 mb-4">
                    <p class="text-xs text-red-700"><strong>❌ Error común:</strong> No pegues el link de la página de ImgBB (ej: <code>ibb.co/abcd</code>).<br>
                    <strong>✅ Correcto:</strong> El link debe terminar en <code>.jpg</code> o <code>.png</code> (ej: <code>i.ibb.co/abcd/imagen.jpg</code>).<br>
                    Usa el botón "Copiar Direct Link" en ImgBB después de subir.</p>
                </div>
                <div class="bg-orange-50 p-4 rounded-xl border border-orange-100 mb-6">
                    <p class="text-xs text-orange-700"><strong>Tip HTML:</strong> Usa <code>&lt;br&gt;</code> para bajar de renglón y <code>&lt;span class="italic font-light opacity-80"&gt;...&lt;/span&gt;</code> para texto fino.</p>
                </div>

                <!-- Category Management -->
                <div class="border-t pt-8 mt-8">
                    <h3 class="text-lg font-bold mb-4 uppercase tracking-widest text-gray-400">Categorías (Grilla de 4)</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <!-- Cat 1 -->
                        <div class="p-4 bg-gray-50 rounded-xl">
                            <label class="block text-[10px] font-bold uppercase mb-1">Cat 1: Nombre</label>
                            <input type="text" id="cat1Name" class="w-full px-3 py-2 border rounded-lg text-sm mb-3">
                            <label class="block text-[10px] font-bold uppercase mb-1">Cat 1: Imagen URL</label>
                            <input type="url" id="cat1Img" class="w-full px-3 py-2 border rounded-lg text-sm font-mono">
                        </div>
                        <!-- Cat 2 -->
                        <div class="p-4 bg-gray-50 rounded-xl">
                            <label class="block text-[10px] font-bold uppercase mb-1">Cat 2: Nombre</label>
                            <input type="text" id="cat2Name" class="w-full px-3 py-2 border rounded-lg text-sm mb-3">
                            <label class="block text-[10px] font-bold uppercase mb-1">Cat 2: Imagen URL</label>
                            <input type="url" id="cat2Img" class="w-full px-3 py-2 border rounded-lg text-sm font-mono">
                        </div>
                        <!-- Cat 3 -->
                        <div class="p-4 bg-gray-50 rounded-xl">
                            <label class="block text-[10px] font-bold uppercase mb-1">Cat 3: Nombre</label>
                            <input type="text" id="cat3Name" class="w-full px-3 py-2 border rounded-lg text-sm mb-3">
                            <label class="block text-[10px] font-bold uppercase mb-1">Cat 3: Imagen URL</label>
                            <input type="url" id="cat3Img" class="w-full px-3 py-2 border rounded-lg text-sm font-mono">
                        </div>
                        <!-- Cat 4 -->
                        <div class="p-4 bg-gray-50 rounded-xl">
                            <label class="block text-[10px] font-bold uppercase mb-1">Cat 4: Nombre</label>
                            <input type="text" id="cat4Name" class="w-full px-3 py-2 border rounded-lg text-sm mb-3">
                            <label class="block text-[10px] font-bold uppercase mb-1">Cat 4: Imagen URL</label>
                            <input type="url" id="cat4Img" class="w-full px-3 py-2 border rounded-lg text-sm font-mono">
                        </div>
                    </div>
                </div>
                <div class="p-4 border border-dashed border-gray-200 rounded-xl">
                    <p class="text-[10px] font-bold uppercase text-gray-400 mb-2">Previsualización del Título:</p>
                    <div id="hero-title-preview" class="font-serif text-2xl leading-tight uppercase tracking-tighter"></div>
                </div>
                <button type="submit" class="w-full bg-orange-500 text-white py-4 rounded-xl font-bold hover:bg-orange-600 shadow-lg shadow-orange-200 transition">Guardar Cambios en Portada</button>
            </form>
        </div>

        <div id="tab-ajustes" class="tab-content hidden bg-white rounded-2xl shadow p-8 max-w-md mx-auto">
            <h2 class="text-xl font-bold mb-6">Ajustes Admin</h2>
            <form id="settings-form" class="space-y-4">
                <input type="text" id="new-admin-user" placeholder="Nuevo Usuario" required class="w-full px-4 py-2 border rounded-lg">
                <input type="password" id="new-admin-pass" placeholder="Nueva Clave" required class="w-full px-4 py-2 border rounded-lg">
                <button type="submit" class="w-full bg-black text-white py-3 rounded-lg font-bold">Actualizar</button>
            </form>
        </div>
    </div>

    <script>
        const AUTH_KEY = 'glamours_admin_auth';
        let productsData = [];
        let usersData = [];

        document.addEventListener('DOMContentLoaded', () => {
            if (localStorage.getItem(AUTH_KEY) === 'true') {
                document.getElementById('admin-login-overlay').classList.add('hidden');
                document.getElementById('admin-panel').classList.remove('hidden');
                loadProducts();
                loadUsers();
            }
            
            document.getElementById('admin-login-form').onsubmit = (e) => {
                e.preventDefault();
                const u = document.getElementById('admin-user').value;
                const p = document.getElementById('admin-pass').value;
                if (u === 'SILVINA' && p === 'SILVINA') {
                    localStorage.setItem(AUTH_KEY, 'true');
                    location.reload();
                } else alert('Acceso denegado');
            };

            document.getElementById('productForm').onsubmit = async (e) => {
                e.preventDefault();
                const id = document.getElementById('edit-id').value;
                const esOferta = document.getElementById('oferta').checked;
                const p = {
                    nombre: document.getElementById('nombre').value,
                    precio: parseFloat(document.getElementById('precio').value),
                    marca: document.getElementById('marca').value,
                    imagenes: [document.getElementById('imagen').value],
                    colores: document.getElementById('colores').value,
                    talles: document.getElementById('talles').value,
                    novedad: document.getElementById('novedad').checked,
                    oferta: esOferta,
                    portada: document.getElementById('portada').checked,
                    descuento: esOferta ? parseInt(document.getElementById('descuento').value) || 0 : 0,
                    descripcion: document.getElementById('descripcion').value
                };
                
                const url = id ? `/api/admin/productos/${id}` : '/api/admin/productos';
                const method = id ? 'PUT' : 'POST';

                const res = await fetch(url, {
                    method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(p)
                });
                if (res.ok) { 
                    resetForm();
                    loadProducts(); 
                } else {
                    alert('Error al guardar producto');
                }
            };

            document.getElementById('config-form').onsubmit = async (e) => {
                e.preventDefault();
                const config = {
                    topBanner: document.getElementById('topBanner').value,
                    heroTitle: document.getElementById('heroTitle').value,
                    heroDesc: document.getElementById('heroDesc').value,
                    heroImage: document.getElementById('heroImage').value,
                    cat1Name: document.getElementById('cat1Name').value,
                    cat1Img: document.getElementById('cat1Img').value,
                    cat2Name: document.getElementById('cat2Name').value,
                    cat2Img: document.getElementById('cat2Img').value,
                    cat3Name: document.getElementById('cat3Name').value,
                    cat3Img: document.getElementById('cat3Img').value,
                    cat4Name: document.getElementById('cat4Name').value,
                    cat4Img: document.getElementById('cat4Img').value
                };
                const res = await fetch('/api/admin/config', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(config)
                });
                if (res.ok) alert('Portada actualizada con éxito ✨');
            };

            document.getElementById('cancel-edit').onclick = resetForm;
            
            document.getElementById('settings-form').onsubmit = async (e) => {
                e.preventDefault();
                const newUser = document.getElementById('new-admin-user').value;
                const newPass = document.getElementById('new-admin-pass').value;
                
                const res = await fetch('/api/admin/update-credentials', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ user: newUser, pass: newPass })
                });
                
                if (res.ok) {
                    alert('Credenciales actualizadas. Por favor reinicia el servidor para aplicar cambios permanentes.');
                    document.getElementById('settings-form').reset();
                } else {
                    alert('Error al actualizar credenciales.');
                }
            };

            loadConfig(); // Load initial config
        });

        async function loadConfig() {
            const res = await fetch('/api/config');
            const data = await res.json();
            if (data) {
                document.getElementById('topBanner').value = data.topBanner || '';
                document.getElementById('heroTitle').value = data.heroTitle || '';
                document.getElementById('heroDesc').value = data.heroDesc || '';
                document.getElementById('heroImage').value = data.heroImage || '';
                document.getElementById('cat1Name').value = data.cat1Name || 'Mujer';
                document.getElementById('cat1Img').value = data.cat1Img || '';
                document.getElementById('cat2Name').value = data.cat2Name || 'Hombre';
                document.getElementById('cat2Img').value = data.cat2Img || '';
                document.getElementById('cat3Name').value = data.cat3Name || 'Niños';
                document.getElementById('cat3Img').value = data.cat3Img || '';
                document.getElementById('cat4Name').value = data.cat4Name || 'Accesorios';
                document.getElementById('cat4Img').value = data.cat4Img || '';
                updateHeroPreview();
            }
        }

        function updateHeroPreview() {
            const val = document.getElementById('heroTitle').value;
            document.getElementById('hero-title-preview').innerHTML = val || 'Previsualización...';
        }

        document.getElementById('heroTitle').addEventListener('input', updateHeroPreview);

        function showTab(id) {
            document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.getElementById('tab-' + id).classList.remove('hidden');
            document.getElementById('btn-' + id).classList.add('active');
        }

        async function loadProducts() {
            const res = await fetch('/api/productos');
            productsData = await res.json();
            const list = document.getElementById('product-list');
            if (productsData.length === 0) {
                list.innerHTML = '<p class="text-center text-gray-400 py-8">No hay productos cargados.</p>';
                return;
            }
            list.innerHTML = productsData.map(p => `
                <div class="flex items-center gap-4 p-4 border rounded-xl bg-gray-50 hover:bg-gray-100">
                    <img src="${p.imagenes[0]}" class="w-16 h-16 object-cover rounded-lg">
                    <div class="flex-1 text-sm">
                        <h4 class="font-bold">${p.nombre}</h4>
                        <p class="text-gray-500">${p.marca} - $${p.precio}</p>
                        <div class="flex gap-2 mt-1">
                            ${p.novedad ? '<span class="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded">NUEVO</span>' : ''}
                            ${p.oferta ? '<span class="text-xs bg-[#E0007F] text-white px-2 py-0.5 rounded">-' + (p.descuento || 0) + '%</span>' : ''}
                        </div>
                    </div>
                    <div class="flex gap-2">
                        <button onclick="editProduct('${p.id}')" class="w-8 h-8 rounded bg-blue-500 text-white hover:bg-blue-600 flex items-center justify-center" title="Editar">
                            <i class="fa-solid fa-pen text-xs"></i>
                        </button>
                        <button onclick="deleteProduct('${p.id}')" class="w-8 h-8 rounded bg-red-500 text-white hover:bg-red-600 flex items-center justify-center" title="Eliminar">
                            <i class="fa-solid fa-trash text-xs"></i>
                        </button>
                    </div>
                </div>
            `).join('');
        }

        function editProduct(id) {
            const p = productsData.find(item => item.id === id);
            if (!p) return;
            document.getElementById('form-title').innerText = 'Editar Producto';
            document.getElementById('edit-id').value = p.id;
            document.getElementById('nombre').value = p.nombre;
            document.getElementById('precio').value = p.precio;
            document.getElementById('marca').value = p.marca;
            document.getElementById('imagen').value = p.imagenes[0];
            document.getElementById('colores').value = p.colores || '';
            document.getElementById('talles').value = p.talles || '';
            document.getElementById('descripcion').value = p.descripcion || '';
            document.getElementById('novedad').checked = p.novedad;
            document.getElementById('oferta').checked = p.oferta;
            document.getElementById('portada').checked = p.portada || false;
            document.getElementById('descuento').value = p.descuento || 0;
            toggleDiscountField();
            document.getElementById('submit-btn').innerText = 'Actualizar Producto';
            document.getElementById('cancel-edit').classList.remove('hidden');
        }

        function resetForm() {
            document.getElementById('productForm').reset();
            document.getElementById('edit-id').value = '';
            document.getElementById('form-title').innerText = 'Nuevo Producto';
            document.getElementById('submit-btn').innerText = 'Guardar';
            document.getElementById('cancel-edit').classList.add('hidden');
            document.getElementById('discount-container').classList.add('hidden');
        }
        
        function toggleDiscountField() {
            const ofertaChecked = document.getElementById('oferta').checked;
            const container = document.getElementById('discount-container');
            if (ofertaChecked) {
                container.classList.remove('hidden');
            } else {
                container.classList.add('hidden');
                document.getElementById('descuento').value = '';
            }
        }

        async function deleteProduct(id) {
            if (!confirm('¿Estás segura de eliminar este producto?')) return;
            try {
                const res = await fetch(`/api/admin/productos/${id}`, { method: 'DELETE' });
                if (res.ok) {
                    loadProducts();
                } else {
                    alert('Error al eliminar producto');
                }
            } catch (e) {
                alert('Error de conexión');
            }
        }

        async function loadUsers() {
            const res = await fetch('/api/admin/users');
            usersData = await res.json();
            document.getElementById('user-list-table').innerHTML = `
                <table class="w-full text-left text-sm">
                    <thead><tr class="bg-gray-50"><th class="p-3">Nombre</th><th class="p-3">Email</th></tr></thead>
                    <tbody>${usersData.map(u => `<tr class="border-b"><td class="p-3">${u.nombre}</td><td class="p-3 text-gray-500">${u.email}</td></tr>`).join('')}</tbody>
                </table>`;
        }

        function logoutAdmin() { localStorage.removeItem(AUTH_KEY); location.reload(); }
        
        function exportUsers() {
            if (usersData.length === 0) return alert('No hay usuarios para exportar');
            let csv = "\uFEFFNombre,Email\n";
            usersData.forEach(u => {
                csv += `"${u.nombre}","${u.email}"\n`;
            });
            const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement("a");
            link.href = URL.createObjectURL(blob);
            link.setAttribute("download", "usuarios_glamours.csv");
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }

        // === IMAGENES FUNCTIONS ===
        function previewImage(event) {
            const file = event.target.files[0];
            if (!file) return;
            
            if (file.size > 20 * 1024 * 1024) {
                alert('La imagen debe ser menor a 5MB');
                return;
            }
            
            const reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById('preview-img').src = e.target.result;
                document.getElementById('preview-img').classList.remove('hidden');
                document.getElementById('image-preview-area').classList.add('hidden');
                document.getElementById('image-result').classList.remove('hidden');
            };
            reader.readAsDataURL(file);
        }

        function copyImageUrl() {
            const urlInput = document.getElementById('image-url-result');
            urlInput.select();
            document.execCommand('copy');
            
            const btn = document.querySelector('#image-result button');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-check"></i> Copiado!';
            setTimeout(() => btn.innerHTML = originalText, 2000);
        }

        function copyImageCode() {
            const codeInput = document.getElementById('image-code-result');
            codeInput.select();
            document.execCommand('copy');
        }

        function resetImageUpload() {
            document.getElementById('image-upload').value = '';
            document.getElementById('preview-img').src = '';
            document.getElementById('preview-img').classList.add('hidden');
            document.getElementById('image-preview-area').classList.remove('hidden');
            document.getElementById('image-result').classList.add('hidden');
        }
    </script>
</body>
</html>

